    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.2",
    "dompurify": "^3.2.2",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jsdom": "^25.0.1",
    "pino-pretty": "^13.1.3",
    "postmark": "^4.0.5",
