# =============================================================================
# Inkflow — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# App
APP_URL=https://inkflow.io
NODE_ENV=development

# Authentication
JWT_SECRET=your-256-bit-secret-here-change-in-production
JWT_REFRESH_SECRET=another-256-bit-secret-change-in-production

# Database
POSTGRES_USER=inkflow
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=inkflow
DATABASE_URL=postgresql://inkflow:change-me-in-production@localhost:5432/inkflow

# Redis
REDIS_PASSWORD=change-me-in-production
REDIS_URL=redis://:change-me-in-production@localhost:6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=https://inkflow.io/api/telegram/webhook
# Admin Telegram IDs (comma-separated) — who can use the bot
TELEGRAM_ADMIN_IDS=123456789,987654321

# Email — Postmark (primary)
POSTMARK_API_TOKEN=your-postmark-token
POSTMARK_WEBHOOK_SECRET=your-postmark-webhook-shared-secret
POSTMARK_FROM_EMAIL=newsletter@inkflow.io
POSTMARK_FROM_NAME=Inkflow

# Email — Resend (fallback)
RESEND_API_KEY=re_...

# Payments — Stripe (global)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Payments — CloudPayments (RU)
CLOUDPAYMENTS_PUBLIC_ID=pk_...
CLOUDPAYMENTS_API_SECRET=your-api-secret

# AI — Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Storage — MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-in-production
MINIO_BUCKET=inkflow

# Security
UNSUBSCRIBE_TOKEN_SECRET=your-32-char-hmac-secret-for-unsubscribe-tokens

# Monitoring
GRAFANA_PASSWORD=change-me-in-production
SENTRY_DSN=https://...@sentry.io/...
