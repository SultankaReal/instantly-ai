# ─── Application ──────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://app.поток.ru

# ─── Authentication ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your-256-bit-hex-secret-here
JWT_REFRESH_SECRET=another-256-bit-hex-secret-here

# ─── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=potok
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=potok

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-password

# ─── Email Credential Encryption ──────────────────────────────────────
# Generate with: openssl rand -hex 32
# MUST be identical across api and worker containers
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ─── YooKassa ─────────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_WEBHOOK_SECRET=your-webhook-secret

# ─── AI (Claude API) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── MinIO ────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-strong-password

# ─── Monitoring ───────────────────────────────────────────────────────
GRAFANA_PASSWORD=change-me-admin-password
